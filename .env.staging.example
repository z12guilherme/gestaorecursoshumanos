# =============================================================
# Variáveis de Ambiente — STAGING
# =============================================================
# Este arquivo é um TEMPLATE. Não commitar valores reais.
# Configure os valores reais como Secrets no GitHub e no Vercel.
#
# Como configurar:
# 1. Crie um projeto separado no Supabase para staging
# 2. Execute o mesmo script SQL de produção nele
# 3. Adicione as chaves abaixo como Secrets no GitHub:
#    Settings → Secrets and variables → Actions
#    - STAGING_SUPABASE_URL
#    - STAGING_SUPABASE_ANON_KEY
# 4. No Vercel, crie um ambiente "Preview" e configure as
#    variáveis de ambiente apontando para o Supabase de staging
# =============================================================

VITE_SUPABASE_URL=https://SEU_PROJETO_STAGING.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_STAGING

VITE_EMAILJS_SERVICE_ID=SEU_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=SEU_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=SUA_PUBLIC_KEY
